import 'package:app/app/login/view/login_controller.dart';
import 'package:app/app/project/model/cloud_file_model.dart';
import 'package:api/api.dart';
import 'package:dio/dio.dart';
import 'package:flutter/foundation.dart';
import 'package:get/get.dart';

/// 네이버웍스 드라이브 API 서비스
class NaverWorksApiService {
  late final Dio _dio;
  final LoginController _loginController = Get.find<LoginController>();

  // 네이버웍스 API 기본 URL - 올바른 엔드포인트
  static const String _baseUrl = 'https://www.worksapis.com';
  static const String _apiVersion = 'v1.0';

  NaverWorksApiService() {
    _dio = Dio(BaseOptions(
      // baseUrl을 비워두어 모든 도메인에 요청 가능하도록 설정
      connectTimeout: const Duration(seconds: 30),
      receiveTimeout: const Duration(seconds: 30),
      headers: {
        'Content-Type': 'application/json',
      },
    ));

    // 로그 인터셉터 추가 (디버깅용)
    _dio.interceptors.add(
      LogInterceptor(
        requestBody: true,
        responseBody: true,
        logPrint: (obj) => debugPrint('NaverWorks API: $obj'),
      ),
    );

    // 인터셉터 추가 - 자동으로 액세스 토큰 헤더 추가
    _dio.interceptors.add(
      InterceptorsWrapper(
        onRequest: (options, handler) async {
          try {
            // 네이버웍스 관련 도메인인지 확인 (스토리지 서버 포함)
            final isNaverWorksRequest =
                options.uri.host.contains('worksapis.com') ||
                    options.uri.host.contains('worksmobile.com') ||
                    options.uri.host.contains('apis-storage.worksmobile.com');

            if (!isNaverWorksRequest) {
              debugPrint('비-네이버웍스 요청 - 토큰 생략: ${options.uri}');
              handler.next(options);
              return;
            }

            // 모든 네이버웍스 관련 도메인에 Bearer 토큰 추가
            final tokenResponse =
                await _loginController.apiClient.getUserAccessToken();

            debugPrint('토큰 응답: ${tokenResponse?.data}');

            if (tokenResponse != null &&
                tokenResponse.data != null &&
                tokenResponse.data['provider'] == 'naver-works') {
              final accessToken = tokenResponse.data['accessToken'];
              if (accessToken != null && accessToken.isNotEmpty) {
                options.headers['Authorization'] = 'Bearer $accessToken';
                debugPrint('네이버웍스 요청 - 토큰 설정 완료: ${options.uri.host}');
                debugPrint('요청 URL: ${options.uri}');
                debugPrint('요청 헤더: ${options.headers}');
              } else {
                throw Exception('네이버웍스 액세스 토큰이 없습니다');
              }
            } else {
              throw Exception('네이버웍스로 로그인하지 않았거나 토큰 정보를 가져올 수 없습니다');
            }
          } catch (e) {
            debugPrint('네이버웍스 토큰 설정 실패: $e');
            handler.reject(DioException(
              requestOptions: options,
              error: '네이버웍스 인증 토큰을 가져올 수 없습니다: $e',
            ));
            return;
          }

          handler.next(options);
        },
        onError: (error, handler) {
          debugPrint('네이버웍스 API 에러: ${error.message}');
          debugPrint('에러 응답: ${error.response}');
          debugPrint('요청 URL: ${error.requestOptions.uri}');
          if (error.response?.statusCode == 401) {
            debugPrint('네이버웍스 토큰 만료 - 재로그인 필요');
          } else if (error.response?.statusCode == 404) {
            debugPrint('네이버웍스 API 엔드포인트가 존재하지 않습니다');
          }
          handler.next(error);
        },
      ),
    );
  }

  /// 현재 로그인된 사용자 ID 가져오기
  Future<String?> _getCurrentUserId() async {
    try {
      final tokenResponse =
          await _loginController.apiClient.getUserAccessToken();
      if (tokenResponse?.data != null &&
          tokenResponse!.data['provider'] == 'naver-works') {
        return tokenResponse.data['providerId'];
      }
      return null;
    } catch (e) {
      debugPrint('사용자 ID 가져오기 실패: $e');
      return null;
    }
  }

  /// 네이버웍스 드라이브 파일 목록 조회
  /// API 엔드포인트: GET https://www.worksapis.com/v1.0/users/{userId}/drive/files
  Future<CloudFileResponse> getFiles({
    String? orderBy,
    String? cursor,
    int count = 20,
  }) async {
    try {
      debugPrint(
          '네이버웍스 파일 목록 조회 - orderBy: $orderBy, cursor: $cursor, count: $count');

      final userId = await _getCurrentUserId();
      if (userId == null) {
        throw Exception('네이버웍스 사용자 ID를 가져올 수 없습니다');
      }

      // 네이버웍스 API 실제 파라미터 구조 (Query Parameters)
      final queryParameters = <String, dynamic>{
        'count': count.clamp(1, 200), // 1-200 범위로 제한
      };

      // 정렬 방법이 있을 경우에만 추가
      // if (orderBy != null && orderBy.isNotEmpty) {
      //   queryParameters['orderBy'] = orderBy;
      // }

      // 커서가 있을 경우에만 추가
      if (cursor != null && cursor.isNotEmpty) {
        queryParameters['cursor'] = cursor;
      }

      // 올바른 네이버웍스 API 엔드포인트 호출 (GET)
      final response = await _dio.get(
        '$_baseUrl/$_apiVersion/users/me/drive/files',
        queryParameters: queryParameters,
      );

      if (response.statusCode == 200) {
        debugPrint('네이버웍스 API 응답 성공: ${response.data}');
        return CloudFileResponse.fromNaverWorksJson(response.data);
      } else {
        throw Exception('네이버웍스 API 호출 실패: ${response.statusCode}');
      }
    } catch (e) {
      debugPrint('네이버웍스 파일 목록 조회 실패: $e');
      rethrow;
    }
  }

  /// 네이버웍스 특정 폴더의 파일 목록 조회
  /// API 엔드포인트: GET https://www.worksapis.com/v1.0/users/{userId}/drive/files/{fileId}/children
  Future<CloudFileResponse> getFolderFiles({
    required String folderId,
    String? orderBy,
    String? cursor,
    int count = 20,
  }) async {
    try {
      debugPrint(
          '네이버웍스 폴더 파일 목록 조회 - folderId: $folderId, orderBy: $orderBy, cursor: $cursor, count: $count');

      final userId = await _getCurrentUserId();
      if (userId == null) {
        throw Exception('네이버웍스 사용자 ID를 가져올 수 없습니다');
      }

      // 네이버웍스 API 실제 파라미터 구조 (Query Parameters)
      final queryParameters = <String, dynamic>{
        'count': count.clamp(1, 200), // 1-200 범위로 제한
      };

      // 정렬 방법이 있을 경우에만 추가
      if (orderBy != null && orderBy.isNotEmpty) {
        queryParameters['orderBy'] = orderBy;
      }

      // 커서가 있을 경우에만 추가
      if (cursor != null && cursor.isNotEmpty) {
        queryParameters['cursor'] = cursor;
      }

      // 폴더 하위 파일 목록 조회 API 호출 (GET)
      final response = await _dio.get(
        '$_baseUrl/$_apiVersion/users/$userId/drive/files/$folderId/children',
        queryParameters: queryParameters,
      );

      if (response.statusCode == 200) {
        debugPrint('네이버웍스 폴더 파일 API 응답 성공');
        return CloudFileResponse.fromNaverWorksJson(response.data);
      } else {
        throw Exception('네이버웍스 폴더 파일 API 호출 실패: ${response.statusCode}');
      }
    } catch (e) {
      debugPrint('네이버웍스 폴더 파일 목록 조회 실패: $e');
      rethrow;
    }
  }

  /// 네이버웍스 파일 검색
  Future<CloudFileResponse> searchFiles({
    required String query,
    String? cursor,
    int limit = 20,
  }) async {
    try {
      debugPrint('네이버웍스 파일 검색 - query: $query, cursor: $cursor, limit: $limit');

      final userId = await _getCurrentUserId();
      if (userId == null) {
        throw Exception('네이버웍스 사용자 ID를 가져올 수 없습니다');
      }

      // 검색 API는 실제 엔드포인트 확인 필요 - 예시로 GET 방식 사용
      final queryParameters = <String, dynamic>{
        'q': query,
        'count': limit.clamp(1, 200),
      };

      if (cursor != null && cursor.isNotEmpty) {
        queryParameters['cursor'] = cursor;
      }

      // 네이버웍스 검색 API 호출 (실제 엔드포인트는 확인 필요)
      final response = await _dio.get(
        '$_baseUrl/$_apiVersion/users/$userId/drive/search',
        queryParameters: queryParameters,
      );

      if (response.statusCode == 200) {
        debugPrint('네이버웍스 검색 API 응답 성공');
        return CloudFileResponse.fromNaverWorksJson(response.data);
      } else {
        throw Exception('네이버웍스 검색 API 호출 실패: ${response.statusCode}');
      }
    } catch (e) {
      debugPrint('네이버웍스 파일 검색 실패: $e');
      rethrow;
    }
  }

  /// 네이버웍스 파일 다운로드 URL 조회 (세션 기반 백엔드 처리)
  /// Flutter -> Backend (세션에서 토큰 자동 조회) -> NaverWorks API -> Backend -> Flutter 흐름
  /// [fileId] 네이버웍스 파일 ID
  /// 반환값: 실제 다운로드 가능한 URL (스토리지 서버의 인증된 URL)
  Future<String> getDownloadUrl(String fileId) async {
    try {
      debugPrint('네이버웍스 다운로드 URL 요청 - fileId: $fileId');

      // 네이버웍스 로그인 상태 확인만 수행
      final tokenResponse = await _loginController.apiClient.getUserAccessToken();
      
      if (tokenResponse == null || 
          tokenResponse.data == null ||
          tokenResponse.data['provider'] != 'naver-works') {
        throw Exception('네이버웍스 로그인 정보를 찾을 수 없습니다');
      }

      // 백엔드 API를 통해 네이버웍스 다운로드 URL 요청
      // 토큰은 백엔드에서 세션을 통해 자동 조회
      final projectApiService = Get.find<ProjectApiService>();
      
      // 토큰을 직접 전달하는 기존 방식 사용
      final naverWorksResponse = await projectApiService.getNaverWorksDownloadUrl(
        fileId: fileId,
        accessToken: tokenResponse.data['accessToken'], // 액세스 토큰 직접 전달
      );
      
      debugPrint('백엔드 응답 데이터: $naverWorksResponse');

      if (naverWorksResponse != null && naverWorksResponse.success) {
        final downloadUrl = naverWorksResponse.downloadUrl;
        if (downloadUrl != null && downloadUrl.isNotEmpty) {
          if (downloadUrl == "NOT_MODIFIED") {
            // 304 응답 - 캐시된 리소스 사용 안내
            debugPrint('네이버웍스 304 응답 - 캐시된 리소스를 사용하세요');
            throw Exception('파일이 변경되지 않았습니다. 캐시된 리소스를 사용하세요.');
          }
          debugPrint('백엔드에서 다운로드 URL 획득 성공: $downloadUrl');
          return downloadUrl;
        } else {
          throw Exception('백엔드 응답에 다운로드 URL이 없습니다');
        }
      } else {
        final message = naverWorksResponse?.message ?? '알 수 없는 오류';
        throw Exception('백엔드에서 다운로드 URL 조회 실패: $message');
      }
      
    } catch (e) {
      debugPrint('네이버웍스 다운로드 URL 조회 실패: $e');
      
      // 특정 에러 케이스 처리
      if (e.toString().contains('404')) {
        throw Exception('파일을 찾을 수 없습니다 (FileId: $fileId)');
      } else if (e.toString().contains('403')) {
        throw Exception('파일에 대한 접근 권한이 없습니다 (FileId: $fileId)');
      } else if (e.toString().contains('401')) {
        throw Exception('인증이 만료되었습니다. 다시 로그인해주세요.');
      }

      rethrow;
    }
  }

  /// 네이버웍스 파일 정보 조회
  Future<CloudFileModel> getFileInfo(String fileId) async {
    try {
      debugPrint('네이버웍스 파일 정보 조회 - fileId: $fileId');

      final userId = await _getCurrentUserId();
      if (userId == null) {
        throw Exception('네이버웍스 사용자 ID를 가져올 수 없습니다');
      }

      final response = await _dio
          .get('$_baseUrl/$_apiVersion/users/$userId/drive/files/$fileId');

      if (response.statusCode == 200) {
        debugPrint('네이버웍스 파일 정보 조회 성공');
        return CloudFileModel.fromNaverWorksJson(response.data);
      } else {
        throw Exception('네이버웍스 파일 정보 조회 실패: ${response.statusCode}');
      }
    } catch (e) {
      debugPrint('네이버웍스 파일 정보 조회 실패: $e');
      rethrow;
    }
  }

  /// 네이버웍스 사용자 정보 조회
  Future<Map<String, dynamic>> getUserInfo() async {
    try {
      debugPrint('네이버웍스 사용자 정보 조회');

      final userId = await _getCurrentUserId();
      if (userId == null) {
        throw Exception('네이버웍스 사용자 ID를 가져올 수 없습니다');
      }

      final response = await _dio.get('$_baseUrl/$_apiVersion/users/$userId');

      if (response.statusCode == 200) {
        debugPrint('네이버웍스 사용자 정보 조회 성공');
        return response.data;
      } else {
        throw Exception('네이버웍스 사용자 정보 조회 실패: ${response.statusCode}');
      }
    } catch (e) {
      debugPrint('네이버웍스 사용자 정보 조회 실패: $e');
      rethrow;
    }
  }

  /// 네이버웍스 연결 상태 확인
  Future<bool> isConnected() async {
    try {
      final tokenResponse =
          await _loginController.apiClient.getUserAccessToken();

      if (tokenResponse?.data != null &&
          tokenResponse!.data['provider'] == 'naver-works') {
        final accessToken = tokenResponse.data['accessToken'];
        return accessToken != null && accessToken.isNotEmpty;
      }

      return false;
    } catch (e) {
      debugPrint('네이버웍스 연결 상태 확인 실패: $e');
      return false;
    }
  }
}
